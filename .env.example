# Banco de dados (PostgreSQL em produção)
DATABASE_URL=jdbc:postgresql://localhost:5432/barberdb
DATABASE_USERNAME=barber
DATABASE_PASSWORD=suasenha

# JWT
JWT_SECRET=gere_uma_chave_base64_de_256bits_aqui
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# E-mail (opcional — se não configurado, emails são silenciados)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seuemail@gmail.com
MAIL_PASSWORD=senha_de_app_do_gmail

# CORS (domínios permitidos separados por vírgula)
CORS_ALLOWED_ORIGINS=https://seudominio.com,https://www.seudominio.com

# Diretório de uploads
UPLOAD_DIR=uploads

# Spring Profile (usa PostgreSQL e desabilita H2 console)
SPRING_PROFILES_ACTIVE=prod
